# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.

# Connection string de Neon (PostgreSQL en la nube)
DATABASE_URL=postgresql://usuario:clave@host.neon.tech/basededatos?sslmode=require

# Clave secreta para las sesiones — genera una larga y aleatoria
# Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria

# Entorno de ejecución
NODE_ENV=production
